MSP_ENV=local
MSP_CONFIG=config/local.toml
MSP_DB_PATH=data/msp.sqlite3
MSP_ACCOUNT_ID=paper-main
MSP_ALLOW_LIVE_MODE=false
MSP_BROKER=paper
MSP_ENABLE_REAL_BROKER=false

# Only set these for later Toss shadow/live integration.
TOSSINVEST_BASE_URL=https://openapi.tossinvest.com
TOSSINVEST_CLIENT_ID=
TOSSINVEST_CLIENT_SECRET=
TOSSINVEST_ACCOUNT_SEQ=
TOSSINVEST_TIMEOUT_SECONDS=10
